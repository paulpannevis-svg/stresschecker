# Python
__pycache__/
*.pyc
*.pyo

# Secrets — NEVER commit
.env
.env.bak*
*.conf.bak*

# Backups (file-based history lives in /opt/backups)
*.bak
*.bak.*
*.bak-*
*.bak_*

# Databases (live data, never in VCS)
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db.*

# Logs
*.log

# Auto-generated
CONTEXT.md
CONTEXT.md.bak*

# Local-only
.claude/

# Toegevoegd 22-05-2026 na CLEANUP_TODO uitvoering — root-level safety
/*.db
/*.current
/*.merge_backup
/*.v1
/*.pre-leerpunt
/templates_backup_*/

# Brede patterns voor backup-leftovers in subdirs
*.backup
*.backup-*

# Specifieke artefacten
toegepast

# Grote media + runtime-output (Fase 1 git-sanering 06-06-2026)
# Video's en backup-tarball zijn te groot/geen bron; /reports/ is gegenereerde PDF-output.
static/img/*.mp4
static/backup-download.tar.gz
# Anker op root: alleen de PDF-OUTPUTmap negeren, NIET templates/reports/ (bronbestanden).
/reports/

# Staging-config (secrets / lokaal, nooit in VCS)
.env.staging
data/stripe_keys*.conf

# --- Toegevoegd 2026-06-28: de-clutter git status (NON-destructief; verwijdert niets) ---
# hlm/ is BEWUST untracked maar draait LIVE op prod als blueprint (app.py:236,
# `from hlm.routes import hlm`). NIET verwijderen — alleen uit `git status` houden.
hlm/
templates/hlm/
# Stale backup-kopieën van VB-templates (de live bron is templates/vb/*.html, WEL tracked).
templates/vb/backup/
templates/vb/vb/
# Backup-tarballs en kapotte template-artefacten (geen bron).
templates/*.tar.gz
*.BROKEN
